NODE_ENV=development
PORT=3002
API_PREFIX=api
API_VERSION=1
LOG_LEVEL=log
CORS_ORIGINS=http://localhost:3000

# Neon PostgreSQL
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require
DB_SSL=true
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000

# Authentication
JWT_SECRET=development-only-jwt-secret-min-32-chars!!
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=tm_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_MAX_AGE_MS=604800000

# Seed the initial admin (pnpm db:seed-admin)
ADMIN_SEED_EMAIL=admin@traffic.local
ADMIN_SEED_PASSWORD=ChangeMe123!
ADMIN_SEED_FULL_NAME=System Administrator

# Email — auto = try Gmail/SMTP, fall back to Ethereal in development
# Gmail: requires App Password (NOT your Google login password)
# https://myaccount.google.com/apppasswords
EMAIL_ENABLED=true
SMTP_MODE=auto
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-gmail-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Traffic Violation Management
